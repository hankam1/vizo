# ============================================================
# SECRETS / USER DATA — must NEVER be committed
# (NOTE: no trailing comments on pattern lines — git treats them literally)
# ============================================================
# API keys (veo / voice)
user_settings.json
# Claude login state
claude_auth.json
# Per-user runtime data (scenarios/voices/languages live in USER_DATA_DIR;
# the default set comes from code _all_builtins(), so users don't need these).
# To ship a scenario to everyone, add it to _all_builtins() in code instead.
user_scenarios.json
user_voices.json
user_languages.json
# Claude browser session (cookies / tokens)
chrome_profile/
# ChatGPT browser session (cookies / tokens)
chrome_profile_gpt/
# generated results
output/
# user-imported scenario files
imported_assets/
# design scratch downloads
_design_dl/

# internal docs / scratch — not for the public repo
DESIGN_BRIEF.md
DESIGN_BRIEF_SCENARIOS.md
ui_prototype.html
debug_dump_ui.py

